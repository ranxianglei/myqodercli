{
  "name": "qoder-wrapper",
  "version": "0.1.0",
  "description": "Drop-in replacement for qodercli with automatic permission bypass",
  "type": "module",
  "bin": {
    "myqodercli": "./dist/bin/cli.cjs"
  },
  "scripts": {
    "build": "tsc --noEmit && node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "dev": "node --import tsx src/bin/cli.ts"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
